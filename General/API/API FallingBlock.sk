import:
	org.bukkit.entity.EntityType

function spawnFallingBlock(loc: location, block: block data = sand) :: entity:
	set {_world} to world of {_loc}

	set {_mobtype} to EntityType.valueOf("FALLING_BLOCK")

	set {_falling} to {_world}.spawnEntity({_loc}, {_mobtype})
	{_falling}.setBlockData({_block})
	{_falling}.setCancelDrop(true)
	{_falling}.setHurtEntities(false)
	
	return {_falling}