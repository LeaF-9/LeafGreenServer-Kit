import:
	java.util.ArrayList
	java.util.HashMap
	java.lang.reflect.Array

function getArrayLength(array: object) :: number:
	return Array.getLength({_array})

function createNewArrayList() :: object:
	set {_arraylist} to new ArrayList()
	return {_arraylist}

function createNewHashMap() :: object:
	set {_hashmap} to new HashMap()
	return {_hashmap}